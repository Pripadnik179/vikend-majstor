# VikendMajstor Production Environment Variables
# Kopiraj ovaj fajl kao .env i popuni vrednosti

# ============================================
# DATABASE - MySQL konekcija
# ============================================
DATABASE_URL=mysql://vikendma_admin:TVOJA_LOZINKA@localhost:3306/vikendma_vikendmajstor

# ============================================
# SESSION - Bezbednost sesije
# ============================================
# Generiši dug random string (min 32 karaktera)
SESSION_SECRET=promeni-ovo-u-siguran-random-string-minimum-32-karaktera

# ============================================
# EMAIL - SMTP konfiguracija
# ============================================
SMTP_HOST=mail.vikendmajstor.rs
SMTP_PORT=465
SMTP_USER=info@vikendmajstor.rs
SMTP_PASSWORD=tvoja-smtp-lozinka

# ============================================
# PRODUCTION SETTINGS
# ============================================
NODE_ENV=production
PORT=5000

# ============================================
# OPCIONO - Stripe za placanja
# ============================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# ============================================
# OPCIONO - Resend za email (alternativa SMTP)
# ============================================
# RESEND_API_KEY=re_...
